{
  "name": "fileworkflow",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "WXT + React + TypeScript Chrome extension for ChatGPT workflow queue automation.",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "compile": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@wxt-dev/module-react": "latest",
    "idb": "latest",
    "react": "latest",
    "react-dom": "latest",
    "wxt": "latest",
    "zustand": "latest"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@types/chrome": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "latest",
    "eslint-plugin-react-hooks": "latest",
    "eslint-plugin-react-refresh": "latest",
    "prettier": "latest",
    "typescript": "latest",
    "typescript-eslint": "latest"
  }
}
