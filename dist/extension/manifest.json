{
  "manifest_version": 3,
  "name": "FileWorkflow ChatGPT Queue",
  "version": "0.1.0",
  "description": "ChatGPT 消息队列面板扩展版。",
  "permissions": ["storage"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "FileWorkflow",
    "default_popup": "popup.html"
  },
  "options_page": "options.html"
}
