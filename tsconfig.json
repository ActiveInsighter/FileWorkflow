{
  "extends": "./.wxt/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "moduleResolution": "Bundler",
    "noEmit": true
  },
  "include": [
    "entrypoints",
    "src/app",
    "src/content-ui",
    "src/features",
    "src/hooks",
    "src/services",
    "src/shared",
    "src/types",
    "wxt.config.ts"
  ],
  "exclude": ["src/components", "src/stores"]
}
